{
  "name": "SkillMCP 配置",
  "version": "1.0.0",
  
  "packages": {
    "web": {
      "default_visible": false,
      "description": "Web 工具包，按需加载"
    }
  },
  
  "server": {
    "host": "0.0.0.0",
    "port": 8000,
    "log_level": "INFO"
  },
  
  "features": {
    "auto_load_defaults": false,  # 不自动加载任何技能包
    "allow_dynamic_load": true,
    "tool_timeout": 30
  }
}
